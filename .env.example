# Blackboard Configuration
BB_URL=https://elearning.shanghaitech.edu.cn:8443
BB_USERNAME=your_student_id
BB_PASSWORD=your_password

# ShanghaiTech SSO Configuration
SSO_URL=https://ids.shanghaitech.edu.cn/authserver/login

# OpenAI API Configuration (for LLM grading)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# Alternative LLM providers (optional)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# DEEPSEEK_API_KEY=sk-your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Playwright Configuration
HEADLESS=false
SLOW_MO=0
BROWSER_TIMEOUT=30000

# Session persistence
SESSION_FILE=session.json

# Logging
LOG_LEVEL=INFO
LOG_FILE=bb_autoagent.log
